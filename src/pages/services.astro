---
import Base from "../layouts/Base.astro";
import { biz, services } from "../data/site";

const groups = [
  { key: "Hydration", n: "01", blurb: "IV infusions and quick vitamin shots, customized to you.", img: "/images/iv-detail.jpg" },
  { key: "Aesthetics", n: "02", blurb: "Natural-looking results from a medical, less-is-more hand.", img: "/images/treatment-room.jpg" },
  { key: "Weight Loss", n: "03", blurb: "Provider-supervised programs built around your body and goals.", img: "/images/glow.jpg" },
  { key: "Wellness", n: "04", blurb: "Hormones, peptides and unhurried primary care.", img: "/images/lounge-detail.jpg" },
] as const;
---
<Base title="Services" description="IV hydration, aesthetics, medical weight loss, hormone therapy and more, all under one roof in Orlando.">
  <section data-hero data-theme="light" class="hero">
    <div class="wrap grid-12 items-center">
      <div class="lg:col-span-5 order-2 lg:order-1 mt-10 lg:mt-0" data-reveal-img>
        <div class="frame aspect-[4/5]">
          <img src="/images/hero-services.jpg" alt="A ThrIVe treatment room" class="w-full h-full object-cover" fetchpriority="high" />
        </div>
      </div>
      <div class="lg:col-span-7 order-1 lg:order-2 lg:pl-6">
        <p class="eyebrow mb-5" data-reveal>What we offer</p>
        <h1 class="display-1" data-reveal data-reveal-delay="1">Medical wellness,<br />head to <span class="accent">toe.</span></h1>
        <p class="lede mt-7" data-reveal data-reveal-delay="2">Every service is overseen by our medical team: a board-certified physician, nurse practitioner and registered nurse. Real care, no shortcuts.</p>
        <div class="flex flex-wrap items-center gap-5 mt-9" data-reveal data-reveal-delay="3">
          <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn btn-primary">Book a consultation <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href="/drip-finder" class="link-underline">Try the Drip Finder</a>
        </div>
      </div>
    </div>
  </section>

  {groups.map((g, gi) => (
    <section data-theme="light" class="section">
      <div class="wrap grid-12 items-start gap-y-8">
        <div class:list={["lg:col-span-5", gi % 2 === 1 ? "lg:order-2" : ""]} data-reveal-img>
          <div class="frame aspect-[4/5] max-w-sm">
            <img src={g.img} alt={g.key} class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class:list={["lg:col-span-7", gi % 2 === 1 ? "lg:order-1 lg:pr-8" : "lg:pl-2"]} data-reveal>
          <p class="eyebrow mb-3">{g.key}</p>
          <h2 class="display-2 mb-8">{g.blurb}</h2>
          <div>
            {services.filter((s) => s.group === g.key).map((s) => (
              <div class="row">
                <span class="display-3 text-ink self-center">{s.name}</span>
                <span class="text-mute text-sm leading-relaxed self-center">{s.blurb}</span>
                <span></span>
                <span class="row__rule"></span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <section data-theme="dark" class="section-air bg-mesh-deep">
    <div class="wrap-narrow text-center">
      <h2 class="display-2" data-reveal>Not sure where to start? We'll build the plan with you.</h2>
      <p class="lede mt-6" data-reveal data-reveal-delay="1" style="margin-inline:auto">Book a consultation and we'll listen first, then design a plan around your preferences, values and goals.</p>
      <div class="flex flex-wrap gap-4 justify-center mt-9" data-reveal data-reveal-delay="2">
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn btn-primary">Book a consultation</a>
        <a href={biz.phoneHref} class="btn btn-ghost">Call {biz.phone}</a>
      </div>
    </div>
  </section>
</Base>
