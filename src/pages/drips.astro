---
import Base from "../layouts/Base.astro";
import { biz, drips } from "../data/site";
---
<Base title="Drip Menu" description="The ThrIVe IV hydration drip menu, twelve signature vitamin blends for energy, recovery, immunity, glow and more.">
  <!-- header -->
  <section data-hero data-theme="light" class="hero">
    <div class="wrap grid-12 items-center">
      <div class="lg:col-span-7">
        <p class="eyebrow mb-5" data-reveal>The drip menu</p>
        <h1 class="display-1" data-reveal data-reveal-delay="1">Twelve blends.<br />One <span class="accent">you.</span></h1>
        <p class="lede mt-7" data-reveal data-reveal-delay="2">Every drip is prepared and given by licensed medical professionals. Not sure which one fits today? Let the Drip Finder match you in seconds.</p>
        <div class="flex flex-wrap items-center gap-5 mt-9" data-reveal data-reveal-delay="3">
          <a href="/drip-finder" class="btn btn-primary">Find your drip <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href={biz.bookingUrl} target="_blank" rel="noopener" class="link-underline">Book a visit</a>
        </div>
      </div>
      <div class="lg:col-span-5 mt-10 lg:mt-0">
        <div class="frame aspect-[4/5]" data-reveal-img>
          <img src="/images/hero-drips.jpg" alt="ThrIVe IV vitamin blends" class="w-full h-full object-cover" fetchpriority="high" />
        </div>
      </div>
    </div>
  </section>

  <!-- lookbook -->
  <section data-theme="light" class="section">
    <div class="wrap">
      {drips.map((d) => (
        <article id={d.slug} class="row scroll-mt-28 !grid-cols-1 sm:!grid-cols-[1fr_auto] !items-start" data-reveal>
          <div class="min-w-0">
            <h2 class="display-3 text-ink">{d.name}</h2>
            <p class="text-mute text-sm mt-2 max-w-[52ch]">{d.treats}</p>
            <div class="flex flex-wrap gap-2 mt-4">
              {d.ingredients.map((ing) => <span class="chip">{ing}</span>)}
            </div>
          </div>
          <div class="flex sm:flex-col sm:items-end gap-3 mt-4 sm:mt-1 items-center">
            <span class="text-mute text-xs">Call or book for pricing</span>
            <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn btn-ghost !py-2 !px-4 text-sm">Book this</a>
          </div>
          <span class="row__rule"></span>
        </article>
      ))}
    </div>
  </section>

  <!-- build your own -->
  <section data-theme="dark" class="section bg-mesh-deep">
    <div class="wrap grid-12 items-center gap-y-8">
      <div class="lg:col-span-8">
        <p class="eyebrow mb-4">Just Hydration</p>
        <h2 class="display-2">Prefer to build<br />your own?</h2>
        <p class="lede mt-5 max-w-xl">Start with our 500ml saline base and add the vitamins and minerals you want. Our providers help you tailor the perfect infusion for the way you feel today.</p>
      </div>
      <div class="lg:col-span-4 lg:text-right">
        <a href="/drip-finder" class="btn btn-primary">Start with the Drip Finder <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>
</Base>
