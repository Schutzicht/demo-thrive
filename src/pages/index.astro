---
import Base from "../layouts/Base.astro";
import DripJourney from "../components/DripJourney.astro";
import DripFinder from "../components/DripFinder.astro";
import { biz, drips, services, testimonials } from "../data/site";

const cardDrips = [drips[2], drips[0], drips[5], drips[6], drips[4], drips[1]];
const groups = ["Hydration", "Aesthetics", "Weight Loss", "Wellness"] as const;
const stats = [
  { count: 12, suffix: "", label: "Signature IV blends, mixed for you" },
  { count: 15, suffix: "+", label: "Years of real medical expertise" },
  { count: 40, suffix: " min", label: "In, out, and feeling new" },
];
---
<Base>
  <!-- ============ HERO ============ -->
  <section class="hero-home grain relative overflow-hidden" data-bg="#FBF4E6">
    <div class="aurora pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="wrap relative grid items-center gap-10 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <span class="sticker bg-sage text-paper" style="--sticker-rot:-3deg" data-reveal>Open today · 9–6</span>
        <h1 class="display-xl mt-4 text-balance" data-reveal style="--reveal-delay:60ms">Thrive,<br />don't just <span class="text-gold-deep">survive.</span></h1>
        <p class="lede mt-5 max-w-xl text-pretty" data-reveal style="--reveal-delay:130ms">Customized IV drips, medical wellness and aesthetics in Orlando, from a team that listens first. Your health is your greatest wealth, so let's invest in it together.</p>
        <div class="mt-7 flex flex-wrap items-center gap-4" data-reveal style="--reveal-delay:200ms">
          <a href="/drip-finder" class="btn-primary btn-press">Find your drip <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href="/drips" class="btn-ghost btn-press">See the drip menu</a>
        </div>
      </div>

      <div class="hero-media relative" data-reveal="scale" style="--reveal-delay:140ms">
        <div class="grid grid-cols-2 gap-3.5">
          <div class="relative col-span-2">
            <div class="blob-a absolute -inset-3 bg-gold-soft" aria-hidden="true"></div>
            <img src="/images/warm-relax.jpg" alt="A guest relaxing during a ThrIVe IV drip" class="blob-a relative aspect-[5/4] w-full object-cover" width="640" height="512" loading="eager" fetchpriority="high" data-parallax="14" />
          </div>
          <div class="relative">
            <div class="blob-b absolute -inset-2 bg-aqua-soft" aria-hidden="true"></div>
            <img src="/images/iv-detail.jpg" alt="A fresh ThrIVe vitamin infusion" class="blob-b relative aspect-square w-full object-cover" width="320" height="320" loading="eager" />
          </div>
          <div class="relative">
            <div class="blob-c absolute -inset-2 bg-blush-soft" aria-hidden="true"></div>
            <img src="/images/warm-hands.jpg" alt="An RN preparing a vitamin drip" class="blob-c relative aspect-square w-full object-cover" width="320" height="320" loading="eager" />
          </div>
        </div>
        <span class="sticker floaty absolute -left-3 top-[44%] bg-gold text-ink" style="--sticker-rot:-8deg">RN-administered</span>
        <span class="sticker floaty floaty--alt absolute -right-2 -bottom-2 bg-ink text-paper" style="--sticker-rot:5deg">We come to you</span>
      </div>
    </div>
  </section>

  <!-- ============ MARQUEE ============ -->
  <section class="section-dark bg-mesh-deep overflow-hidden py-5 marquee-band" data-bg="#14201A">
    <div class="marquee-track items-center">
      {[...drips, ...drips].map((d) => (
        <span class="flex items-center whitespace-nowrap">
          <span class="font-display text-xl font-medium text-paper/90 px-7">{d.name}</span>
          <svg width="13" height="16" viewBox="0 0 24 30" fill="none" class="shrink-0" aria-hidden="true"><path d="M12 2C12 2 4 14 4 20a8 8 0 0 0 16 0C20 14 12 2 12 2Z" fill="var(--color-gold-soft)" opacity="0.7"/></svg>
        </span>
      ))}
    </div>
  </section>

  <!-- ============ DRIP MENU "WORLDS" ============ -->
  <section class="relative wrap py-24 sm:py-32" data-bg="#FBF4E6">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-12">
      <div data-reveal>
        <p class="font-hand text-3xl text-gold-deep sm:text-4xl">Pick your potion</p>
        <h2 class="display-lg mt-1 text-balance">Twelve blends,<br />mixed for how you feel.</h2>
      </div>
      <a href="/drips" class="link-hand" data-reveal style="--reveal-delay:80ms">All twelve blends
        <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {cardDrips.map((d, i) => (
        <a href={`/drips#${d.slug}`} class="card-pop btn-press group relative overflow-hidden p-7" data-reveal style={`--reveal-delay:${(i % 3) * 80}ms; --card-c:${d.color}; --pop-rot:${i % 2 === 0 ? "-1deg" : "1deg"}`}>
          <span class="absolute -right-8 -top-8 h-28 w-28 rounded-full opacity-20 transition-opacity duration-500 group-hover:opacity-40" style={`background:${d.color}`} aria-hidden="true"></span>
          <span class="relative grid h-12 w-12 place-items-center rounded-full" style={`background:color-mix(in oklab, ${d.color} 18%, white); color:${d.color}`}>
            <svg width="22" height="26" viewBox="0 0 24 30" fill="none"><path d="M12 2C12 2 4 14 4 20a8 8 0 0 0 16 0C20 14 12 2 12 2Z" fill="currentColor"/></svg>
          </span>
          <h3 class="display-sm mt-5 text-ink">{d.name}</h3>
          <p class="mt-2 text-sm leading-relaxed text-mist">{d.treats}</p>
          <span class="chip mt-5" style={`border-color:color-mix(in oklab, ${d.color} 45%, transparent); color:${d.color}`}>{d.tag}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ DRIP JOURNEY (signature scroll) ============ -->
  <div data-bg="#FFFDF7" class="bg-paper"><DripJourney /></div>

  <!-- ============ STATS ============ -->
  <section class="section-dark bg-mesh-deep relative overflow-hidden py-20 sm:py-24" data-bg="#14201A">
    <span class="font-hand absolute right-6 top-8 text-3xl text-gold-soft/70 -rotate-6 hidden sm:block" aria-hidden="true">feel the difference</span>
    <div class="wrap grid gap-10 sm:grid-cols-3 text-center sm:text-left">
      {stats.map((s, i) => (
        <div data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <p class="display-lg text-gold-soft"><span data-count={s.count} data-suffix={s.suffix}>0{s.suffix}</span></p>
          <p class="mt-2 text-sm leading-snug text-paper/70 max-w-[22ch] mx-auto sm:mx-0">{s.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="relative wrap py-24 sm:py-32" data-bg="#FBF4E6">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div data-reveal>
        <p class="font-hand text-3xl text-gold-deep sm:text-4xl">More than a drip</p>
        <h2 class="display-lg mt-1 text-balance">A whole menu of medical wellness.</h2>
        <p class="lede mt-5 text-pretty">From aesthetics to hormone therapy and medically supervised weight loss, all under one roof, all overseen by our medical team.</p>
        <a href="/services" class="link-hand mt-7 inline-flex">Explore all services
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2" data-reveal="right" style="--reveal-delay:80ms">
        {groups.map((g, i) => {
          const c = ["var(--color-aqua)","var(--color-blush)","var(--color-sun)","var(--color-sage)"][i];
          return (
            <div class="card-pop p-6" style={`--pop-rot:${i % 2 === 0 ? "-1deg" : "1deg"}`}>
              <span class="block h-1.5 w-10 rounded-full" style={`background:${c}`}></span>
              <h3 class="display-sm mt-4 text-ink">{g}</h3>
              <p class="mt-2 text-sm leading-relaxed text-mist">{services.filter((s) => s.group === g).map((s) => s.name).join(", ")}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ============ FOUNDER ============ -->
  <section class="relative overflow-hidden py-24 sm:py-28" data-bg="#FDF1DA" style="background:#FDF1DA">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="relative mx-auto w-full max-w-sm" data-reveal="left">
        <div class="blob-b absolute -inset-3 bg-gold-soft" aria-hidden="true"></div>
        <img src="/images/patricia.jpg" alt="Patricia Miller, founder of ThrIVe" class="blob-b relative aspect-square w-full object-cover" width="520" height="520" loading="lazy" data-parallax="10" />
        <span class="sticker absolute -right-2 bottom-4 bg-paper text-gold-deep" style="--sticker-rot:5deg">Founder & nurse</span>
      </div>
      <div data-reveal style="--reveal-delay:80ms">
        <p class="eyebrow">The founder</p>
        <blockquote class="font-display text-2xl font-medium leading-snug text-ink mt-4 sm:text-3xl text-balance">"We listen to you. You're our priority, never a number on a clipboard."</blockquote>
        <p class="mt-6 max-w-xl leading-relaxed text-mist">Patricia Miller, MSN, ARNP, FNP-BC founded ThrIVe in 2020, shortly after surgery to remove a benign brain tumor. That turning point inspired a place where her community could truly invest in their health. She brings more than 15 years in critical care and preventative medicine.</p>
        <a href="/about" class="link-hand mt-7 inline-flex">Read her story
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ DRIP FINDER ============ -->
  <section class="section-dark bg-mesh-deep relative overflow-hidden py-24 sm:py-32" data-bg="#14201A">
    <div class="wrap relative z-10"><DripFinder /></div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="relative wrap py-24 sm:py-32" data-bg="#FBF4E6">
    <div class="mx-auto max-w-2xl text-center mb-14" data-reveal>
      <p class="font-hand text-3xl text-gold-deep sm:text-4xl">Loved in Orlando</p>
      <h2 class="display-lg mt-1 text-balance">People keep coming back.</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t, i) => (
        <figure class="card-pop p-7" data-reveal style={`--reveal-delay:${(i % 3) * 80}ms; --pop-rot:${i % 2 === 0 ? "-1.2deg" : "1.2deg"}`}>
          <div class="flex gap-1 text-gold mb-3" aria-hidden="true">
            {[0,1,2,3,4].map(() => <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.2 6.8.8-5 4.7 1.3 6.7L12 17.8 5.9 20.4 7.2 13.7l-5-4.7 6.8-.8L12 2Z"/></svg>)}
          </div>
          <blockquote class="leading-relaxed text-ink">{t.quote}</blockquote>
          <figcaption class="mt-4 font-display font-semibold text-sm text-mist">{t.name}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="section-dark bg-mesh-deep relative overflow-hidden py-24 sm:py-32 text-center" data-bg="#14201A">
    <span class="sticker absolute left-8 top-12 bg-gold text-ink hidden sm:inline-block" style="--sticker-rot:-7deg" data-reveal>No clipboard rush</span>
    <div class="wrap-narrow relative z-10">
      <p class="eyebrow" data-reveal>Ready when you are</p>
      <h2 class="display-lg mt-3 text-balance" data-reveal style="--reveal-delay:60ms">Feel like yourself again.</h2>
      <p class="lede mx-auto mt-5 max-w-xl text-pretty" data-reveal style="--reveal-delay:120ms">Book a visit at the lounge, or have us come to you with a mobile house call across Orlando.</p>
      <div class="mt-9 flex flex-wrap justify-center gap-4" data-reveal style="--reveal-delay:180ms">
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn-primary btn-press">Book your visit</a>
        <a href="/contact" class="btn-ghost btn-press !text-paper !border-white/25">Request a house call</a>
      </div>
    </div>
  </section>
</Base>
