---
import Base from "../layouts/Base.astro";
import { biz } from "../data/site";
const tiers = [
  { name: "ThrIVe One", drips: "1 drip / month", popular: false, c: "var(--color-aqua)",
    perks: ["One signature IV drip each month", "Member pricing on all services", "Priority booking"] },
  { name: "ThrIVe Two", drips: "2 drips / month", popular: true, c: "var(--color-gold)",
    perks: ["Two signature IV drips each month", "10% off add-on vitamins and shots", "Member pricing on all services", "Priority booking and rollover"] },
  { name: "ThrIVe Four", drips: "4 drips / month", popular: false, c: "var(--color-blush)",
    perks: ["Four signature IV drips each month", "Complimentary vitamin shot monthly", "Best member pricing on aesthetics", "Priority booking and rollover", "Bring-a-friend guest pass"] },
];
const extras = [
  { title: "ThrIVe Party", blurb: "Bring the lounge to your celebration: birthdays, bridal weekends, game day. We set up, you glow.", c: "var(--color-blush)" },
  { title: "Corporate Wellness", blurb: "Keep your team performing at their best with on-site hydration days for busy offices.", c: "var(--color-aqua)" },
];
---
<Base title="Memberships" description="ThrIVe membership plans, parties and corporate wellness, make feeling your best a habit.">
  <!-- hero -->
  <section class="grain relative overflow-hidden pt-32 pb-10 sm:pt-40" data-bg="#FBF4E6">
    <div class="aurora pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="wrap relative text-center max-w-3xl mx-auto">
      <p class="font-hand text-3xl text-gold-deep sm:text-4xl" data-reveal>Make it a habit</p>
      <h1 class="display-xl mt-1 text-balance" data-reveal style="--reveal-delay:60ms">Wellness, <span class="text-gold-deep">on repeat.</span></h1>
      <p class="lede mt-6 mx-auto max-w-xl text-pretty" data-reveal style="--reveal-delay:130ms">Monthly drip plans with member pricing across every service. Pause or change any time, your wellness, your pace.</p>
    </div>
  </section>

  <!-- tiers -->
  <section class="relative wrap pb-20 sm:pb-24" data-bg="#FBF4E6">
    <div class="grid gap-5 lg:grid-cols-3 items-stretch">
      {tiers.map((t, i) => (
        <div class:list={["relative flex flex-col rounded-[24px] p-8", t.popular ? "section-dark bg-mesh-deep lg:-mt-4 lg:mb-4" : "card-pop"]} data-reveal style={`--reveal-delay:${i * 80}ms`}>
          {t.popular && <span class="sticker absolute -top-4 right-6 bg-gold text-ink" style="--sticker-rot:5deg">Most loved</span>}
          <span class="block h-1.5 w-12 rounded-full" style={`background:${t.c}`}></span>
          <h2 class:list={["display-sm mt-4", t.popular ? "text-paper" : "text-ink"]}>{t.name}</h2>
          <p class:list={["text-sm mt-1", t.popular ? "text-paper/65" : "text-mist"]}>{t.drips}</p>
          <ul class="my-7 space-y-3 grow">
            {t.perks.map((p) => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke={t.popular ? "var(--color-gold-soft)" : "var(--color-gold)"} stroke-width="2.4" class="mt-0.5 shrink-0"><path d="M20 6L9 17l-5-5"/></svg>
                <span class:list={[t.popular ? "text-paper/85" : "text-mist"]}>{p}</span>
              </li>
            ))}
          </ul>
          <a href={biz.bookingUrl} target="_blank" rel="noopener" class:list={["btn-press justify-center", t.popular ? "btn-primary" : "btn-ghost"]}>Become a member</a>
        </div>
      ))}
    </div>
    <p class="text-center text-sm text-mist mt-6">Pricing shared in consultation. Call <a href={biz.phoneHref} class="text-gold-deep font-semibold">{biz.phone}</a> for current rates.</p>
  </section>

  <!-- extras -->
  <section class="relative overflow-hidden py-24 sm:py-28" data-bg="#FDF1DA" style="background:#FDF1DA">
    <div class="wrap">
      <h2 class="display-lg max-w-lg text-balance" data-reveal>More ways to thrive together.</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-2" data-reveal style="--reveal-delay:80ms">
        {extras.map((e, i) => (
          <div class="card-pop p-8" style={`--pop-rot:${i % 2 === 0 ? "-1deg" : "1deg"}`}>
            <span class="block h-1.5 w-12 rounded-full" style={`background:${e.c}`}></span>
            <h3 class="display-sm mt-4 text-ink">{e.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-mist">{e.blurb}</p>
            <a href="/contact" class="link-hand mt-5 inline-flex text-sm">Plan it with us
              <svg class="arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
