---
import Base from "../layouts/Base.astro";
import { biz } from "../data/site";
const values = [
  { t: "We listen first", d: "More time with your provider, then a plan built around your preferences and values.", c: "var(--color-aqua)" },
  { t: "Real people, real care", d: "A team that genuinely cares about your wellness. You're our priority, not a number.", c: "var(--color-blush)" },
  { t: "Health is wealth", d: "Wellness is a continuum. We help you find balance so you feel your best while you live.", c: "var(--color-sun)" },
];
const team = [
  { role: "Medical Director", note: "Board-certified collaborating physician overseeing every protocol." },
  { role: "Nurse Practitioner", note: "Board-certified, leading your consultations and treatment plans." },
  { role: "Registered Nurse", note: "Critical-care trained, the steady hands behind every infusion." },
  { role: "Administrator", note: "Keeping your experience seamless from booking to follow-up." },
];
---
<Base title="About" description="The story of ThrIVe Hydration & Spa and founder Patricia Miller, MSN, ARNP, FNP-BC.">
  <!-- hero -->
  <section class="section-dark bg-mesh-deep relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-24" data-bg="#14201A">
    <span class="font-hand absolute right-8 top-28 text-3xl text-gold-soft/60 -rotate-6 hidden sm:block" aria-hidden="true">be you, fully</span>
    <div class="wrap relative max-w-4xl">
      <p class="eyebrow" data-reveal>Our story</p>
      <h1 class="display-xl mt-3 text-balance" data-reveal style="--reveal-delay:60ms">Thrive and be <span class="text-gold-soft">you, fully.</span></h1>
      <p class="lede mt-6 max-w-2xl text-pretty" data-reveal style="--reveal-delay:130ms">We serve jet-setters, entrepreneurs, busy parents and athletes, with customized infusions and a huge emphasis on health and wellness.</p>
    </div>
  </section>

  <!-- founder -->
  <section class="relative overflow-hidden py-24 sm:py-28" data-bg="#FBF4E6">
    <div class="wrap grid items-center gap-12 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="relative mx-auto w-full max-w-sm" data-reveal="left">
        <div class="blob-a absolute -inset-3 bg-gold-soft" aria-hidden="true"></div>
        <img src="/images/patricia.jpg" alt="Patricia Miller, founder" class="blob-a relative aspect-square w-full object-cover" width="520" height="520" loading="lazy" data-parallax="10" />
        <span class="sticker absolute -right-2 bottom-5 bg-paper text-gold-deep" style="--sticker-rot:5deg">Founder & nurse</span>
      </div>
      <div data-reveal style="--reveal-delay:80ms">
        <p class="eyebrow">Patricia Miller, MSN, ARNP, FNP-BC</p>
        <blockquote class="font-display text-2xl font-medium leading-snug text-ink mt-4 sm:text-3xl text-balance">"We listen to you. You're our priority."</blockquote>
        <p class="mt-6 max-w-xl leading-relaxed text-mist">Patricia established ThrIVe in 2020, shortly after undergoing a craniectomy to remove a benign brain tumor. The experience reshaped how she saw health, and inspired her to create real wellness resources for her community.</p>
        <p class="mt-4 max-w-xl leading-relaxed text-mist">She brings more than 15 years of medical expertise in critical care, fluid and electrolyte balance and preventative medicine, blending IV hydration, functional medicine and anti-aging care into one thoughtful plan.</p>
      </div>
    </div>
  </section>

  <!-- values -->
  <section class="relative wrap pb-8" data-bg="#FBF4E6">
    <h2 class="display-lg max-w-xl text-balance" data-reveal>The way ThrIVe cares.</h2>
    <div class="mt-10 grid gap-5 md:grid-cols-3">
      {values.map((v, i) => (
        <div class="card-pop p-7" style={`--pop-rot:${i % 2 === 0 ? "-1deg" : "1deg"}`} data-reveal style={`--reveal-delay:${i * 80}ms`}>
          <span class="block h-1.5 w-10 rounded-full" style={`background:${v.c}`}></span>
          <h3 class="display-sm mt-4 text-ink">{v.t}</h3>
          <p class="mt-2 text-sm leading-relaxed text-mist">{v.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- community image -->
  <section class="relative wrap py-20 sm:py-24" data-bg="#FBF4E6">
    <div class="relative" data-reveal="scale">
      <img src="/images/community.jpg" alt="The ThrIVe community" class="w-full rounded-[28px] object-cover aspect-[21/9]" loading="lazy" />
      <span class="sticker absolute left-6 bottom-6 bg-gold text-ink" style="--sticker-rot:-4deg">Our people</span>
    </div>
  </section>

  <!-- team -->
  <section class="relative wrap pb-24 sm:pb-28" data-bg="#FBF4E6">
    <div class="max-w-xl mb-10" data-reveal>
      <p class="font-hand text-3xl text-gold-deep sm:text-4xl">The team</p>
      <h2 class="display-lg mt-1 text-balance">Experience you can feel safe in.</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal style="--reveal-delay:80ms">
      {team.map((m, i) => (
        <div class="card-pop p-6" style={`--pop-rot:${i % 2 === 0 ? "-1deg" : "1deg"}`}>
          <h3 class="display-sm text-ink" style="font-size:1.2rem">{m.role}</h3>
          <p class="mt-2 text-sm leading-relaxed text-mist">{m.note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section-dark bg-mesh-deep relative overflow-hidden py-24 sm:py-28 text-center" data-bg="#14201A">
    <div class="wrap-narrow">
      <h2 class="display-lg text-balance" data-reveal>Ready to feel like yourself again?</h2>
      <div class="mt-8 flex flex-wrap justify-center gap-4" data-reveal style="--reveal-delay:80ms">
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn-primary btn-press">Book your visit</a>
        <a href="/drip-finder" class="btn-ghost btn-press !text-paper !border-white/25">Find my drip</a>
      </div>
    </div>
  </section>
</Base>
