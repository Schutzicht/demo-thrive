---
import Base from "../layouts/Base.astro";
import DripFinder from "../components/DripFinder.astro";
const steps = [
  { t: "Tell us how you feel", d: "Pick the symptom or goal that fits today.", c: "var(--color-aqua)" },
  { t: "Meet your match", d: "We suggest the real ThrIVe blend built for it.", c: "var(--color-blush)" },
  { t: "Book & relax", d: "A provider confirms your plan and you're set.", c: "var(--color-sun)" },
];
---
<Base title="Drip Finder" description="Tell us how you feel and we'll match you with the perfect ThrIVe IV blend.">
  <!-- hero -->
  <section class="grain relative overflow-hidden pt-32 pb-12 sm:pt-40" data-bg="#FBF4E6">
    <div class="aurora pointer-events-none absolute inset-0" aria-hidden="true"></div>
    <div class="wrap relative grid items-center gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <span class="sticker bg-aqua text-paper" style="--sticker-rot:-3deg" data-reveal>60-second match</span>
        <h1 class="display-xl mt-5 text-balance" data-reveal style="--reveal-delay:60ms">Your body knows.<br />Let's <span class="text-gold-deep">listen.</span></h1>
        <p class="lede mt-6 max-w-xl text-pretty" data-reveal style="--reveal-delay:130ms">A quick, no-pressure way to find the blend made for today. Tap how you feel, and we'll do the rest. The final call is always made with your provider.</p>
        <a href="#finder" class="btn-primary btn-press mt-8" data-reveal style="--reveal-delay:200ms">Start the finder
          <svg class="arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
        </a>
      </div>
      <div class="relative mx-auto w-full max-w-sm" data-reveal="scale" style="--reveal-delay:120ms">
        <div class="blob-a absolute -inset-3 bg-aqua-soft" aria-hidden="true"></div>
        <img src="/images/warm-relax.jpg" alt="A relaxed ThrIVe guest" class="blob-a relative aspect-square w-full object-cover" width="520" height="520" loading="eager" data-parallax="12" />
        <span class="sticker floaty absolute -right-2 bottom-6 bg-gold text-ink" style="--sticker-rot:6deg">Feel-better, fast</span>
      </div>
    </div>
  </section>

  <!-- finder -->
  <section id="finder" class="section-dark bg-mesh-deep relative overflow-hidden py-20 sm:py-28 scroll-mt-20" data-bg="#14201A">
    <div class="wrap relative z-10"><DripFinder /></div>
  </section>

  <!-- steps -->
  <section class="relative wrap py-24 sm:py-28" data-bg="#FBF4E6">
    <div class="grid gap-8 sm:grid-cols-3">
      {steps.map((s, i) => (
        <div data-reveal style={`--reveal-delay:${i * 90}ms`}>
          <span class="grid h-12 w-12 place-items-center rounded-full font-display font-semibold text-lg text-paper" style={`background:${s.c}`}>{i + 1}</span>
          <h3 class="display-sm mt-4 text-ink">{s.t}</h3>
          <p class="mt-2 text-sm text-mist">{s.d}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
