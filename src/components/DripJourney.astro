---
// Signature scroll-showpiece: a glowing droplet travels down a winding IV line
// through "your visit", station by station, as you scroll.
type Stop = { time: string; title: string; text: string; color: string };
const stops: Stop[] = [
  { time: "Min 0", title: "A real conversation", text: "No clipboard rush. Your provider listens first, checks how you actually feel, and builds the plan around you.", color: "var(--color-aqua)" },
  { time: "Min 5", title: "Your blend, mixed fresh", text: "From twelve signature drips we pick the one your body is asking for, or build one just for today.", color: "var(--color-gold)" },
  { time: "Min 10", title: "Settle into the lounge", text: "Recline in a warm chair, a soft throw, a glass of infused water. The gentle part begins.", color: "var(--color-sage)" },
  { time: "Min 40", title: "Hydrated, head to toe", text: "Vitamins and minerals straight to where they work. Most visits are done in about thirty to forty minutes.", color: "var(--color-blush)" },
  { time: "Later", title: "Back to your day, glowing", text: "You walk out lighter, clearer, brighter. And if you'd rather not leave the couch, we come to you.", color: "var(--color-sun)" },
];
---
<section id="journey" class="relative wrap py-24 sm:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <p class="font-hand text-3xl text-gold-deep sm:text-4xl" data-reveal>Drip, drip, glow</p>
    <h2 class="display-md mt-2 text-balance" data-reveal style="--reveal-delay:60ms">Your visit, drop by drop</h2>
    <p class="lede mt-5 text-pretty" data-reveal style="--reveal-delay:120ms">Scroll along with the drop and see how a ThrIVe visit actually feels, from the first hello to the last glow.</p>
  </div>

  <div id="drip-stage" class="relative mt-16">
    <svg id="drip-track" class="pointer-events-none absolute left-5 top-0 h-full w-10 md:left-1/2 md:w-40 md:-translate-x-1/2" viewBox="0 0 160 1600" preserveAspectRatio="none" fill="none" aria-hidden="true">
      <path id="drip-path" d="M80 0 C 80 120, 20 180, 20 320 S 140 520, 140 680 S 20 880, 20 1040 S 140 1240, 140 1400 C 140 1500, 80 1540, 80 1600"
        stroke="color-mix(in oklab, var(--color-ink) 20%, transparent)" stroke-width="3" stroke-dasharray="2 13" stroke-linecap="round" vector-effect="non-scaling-stroke"></path>
    </svg>

    <div id="drip-drop" class="pointer-events-none absolute left-5 top-0 z-10 -translate-x-1/2 -translate-y-1/2 md:left-1/2" aria-hidden="true">
      <svg width="40" height="52" viewBox="0 0 40 52" class="drop-shadow-lg">
        <defs><radialGradient id="dg" cx="35%" cy="30%" r="75%"><stop offset="0%" stop-color="#FBE3A8"/><stop offset="55%" stop-color="var(--color-gold)"/><stop offset="100%" stop-color="var(--color-gold-deep)"/></radialGradient></defs>
        <path d="M20 2C20 2 4 22 4 33a16 16 0 0 0 32 0C36 22 20 2 20 2Z" fill="url(#dg)"/>
        <ellipse cx="14" cy="26" rx="4.5" ry="6" fill="#fff" opacity="0.5"/>
      </svg>
    </div>

    <ol class="relative space-y-16 md:space-y-28">
      {stops.map((s, i) => (
        <li class:list={["relative flex pl-16 md:w-1/2 md:pl-0", i % 2 === 0 ? "md:pr-24 md:text-right md:justify-end" : "md:ml-auto md:pl-24"]}>
          <div class="max-w-sm" data-reveal={i % 2 === 0 ? "left" : "right"}>
            <span class="sticker text-paper" style={`background-color:${s.color}; --sticker-rot:${i % 2 === 0 ? "-3deg" : "3deg"}`}>{s.time}</span>
            <h3 class="display-sm mt-4">{s.title}</h3>
            <p class="mt-3 text-pretty leading-relaxed text-mist">{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  const stage = document.getElementById("drip-stage");
  const path = document.getElementById("drip-path") as unknown as SVGPathElement | null;
  const drop = document.getElementById("drip-drop");
  const track = document.getElementById("drip-track");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (stage && path && drop && track && !reduce) {
    const total = path.getTotalLength();
    let ticking = false;
    const update = () => {
      ticking = false;
      const r = stage.getBoundingClientRect();
      const vh = window.innerHeight;
      const p = Math.min(1, Math.max(0, (vh * 0.7 - r.top) / (r.height - vh * 0.15)));
      const pt = path.getPointAtLength(p * total);
      const tr = track.getBoundingClientRect();
      const x = tr.left - r.left + (pt.x / 160) * tr.width;
      const y = (pt.y / 1600) * tr.height;
      drop.style.transform = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%)`;
    };
    window.addEventListener("scroll", () => { if (!ticking) { requestAnimationFrame(update); ticking = true; } }, { passive: true });
    window.addEventListener("resize", update, { passive: true });
    update();
  } else if (drop) { drop.style.display = "none"; }
</script>
