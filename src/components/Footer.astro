---
import { biz, nav } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="section-dark bg-mesh-deep relative overflow-hidden">
  <div class="wrap relative z-10 pt-4 pb-12">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_1fr_1fr]">
      <div>
        <a href="/" class="font-display text-3xl font-semibold text-paper">thr<span class="text-gold-soft">IV</span>e</a>
        <p class="lede mt-5 max-w-sm">{biz.subtitle}. Warm, real care: IV therapy, medical wellness and aesthetics from people who put your health first.</p>
        <p class="font-hand text-gold-soft text-2xl mt-5">See you in the lounge.</p>
        <div class="flex gap-3 mt-6">
          <a href={biz.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid place-items-center w-11 h-11 rounded-full border border-white/15 text-paper/85 hover:bg-gold hover:text-ink hover:border-gold transition-colors btn-press">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={biz.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid place-items-center w-11 h-11 rounded-full border border-white/15 text-paper/85 hover:bg-gold hover:text-ink hover:border-gold transition-colors btn-press">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1.4-3 3.3V11H8.5v3H11v6h3v-6h2.4l.6-3H14V9.5c0-.4.3-.5.7-.5Z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="eyebrow mb-5">Explore</h3>
        <ul class="space-y-2.5 text-paper/80" style="font-family:var(--font-display)">
          {nav.map((n) => <li><a href={n.href} class="hover:text-gold-soft transition-colors">{n.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="eyebrow mb-5">Visit & book</h3>
        <ul class="space-y-3 text-sm text-paper/80 leading-relaxed">
          <li><a href={biz.mapUrl} target="_blank" rel="noopener" class="hover:text-gold-soft transition-colors">{biz.address}</a></li>
          <li><a href={biz.phoneHref} class="hover:text-gold-soft transition-colors">{biz.phone}</a></li>
          <li><a href={`mailto:${biz.email}`} class="hover:text-gold-soft transition-colors">{biz.email}</a></li>
        </ul>
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn-primary btn-press mt-6 !py-2.5">Book online</a>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-6 flex flex-col sm:flex-row gap-3 justify-between text-xs text-paper/45">
      <p>© {year} {biz.name}. Thrive, don't just survive.</p>
      <p>Demo concept by <a href="https://agensea.nl" target="_blank" rel="noopener" class="text-paper/70 hover:text-gold-soft">Agensea</a></p>
    </div>
  </div>
</footer>
