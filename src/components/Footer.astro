---
import { biz, nav } from "../data/site";
const year = new Date().getFullYear();
---
<footer data-theme="dark" class="bg-mesh-deep relative overflow-hidden">
  <div class="wrap section relative z-10">
    <div class="grid gap-12 lg:grid-cols-[1.3fr_1fr_1fr]">
      <div>
        <a href="/" class="text-ice text-2xl font-medium tracking-tight">thr<span class="brand-iv">IV</span>e</a>
        <p class="lede mt-5 max-w-sm">{biz.subtitle}. Medical wellness, IV therapy and aesthetics, delivered by real people who put your health first.</p>
        <div class="flex gap-3 mt-7">
          <a href={biz.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="grid place-items-center w-10 h-10 rounded-[3px] border border-[var(--hair-dark)] text-ice/80 hover:text-ink hover:bg-aqua-light hover:border-aqua-light transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.3" cy="6.7" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href={biz.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="grid place-items-center w-10 h-10 rounded-[3px] border border-[var(--hair-dark)] text-ice/80 hover:text-ink hover:bg-aqua-light hover:border-aqua-light transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1.4-3 3.3V11H8.5v3H11v6h3v-6h2.4l.6-3H14V9.5c0-.4.3-.5.7-.5Z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="eyebrow mb-5">Explore</h3>
        <ul class="space-y-2.5 text-ice/75">
          {nav.map((n) => <li><a href={n.href} class="link-underline !text-ice/75">{n.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="eyebrow mb-5">Visit & book</h3>
        <ul class="space-y-3 text-sm text-ice/75 leading-relaxed">
          <li><a href={biz.mapUrl} target="_blank" rel="noopener" class="hover:text-aqua-light transition-colors">{biz.address}</a></li>
          <li><a href={biz.phoneHref} class="hover:text-aqua-light transition-colors">{biz.phone}</a></li>
          <li><a href={`mailto:${biz.email}`} class="hover:text-aqua-light transition-colors">{biz.email}</a></li>
        </ul>
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn btn-ghost mt-6 !py-2.5">Book online</a>
      </div>
    </div>

    <div class="hairline-dark my-12"></div>
    <div class="flex flex-col sm:flex-row gap-3 justify-between text-xs text-ice/45">
      <p>© {year} {biz.name}. Thrive, don't just survive.</p>
      <p>Demo concept by <a href="https://agensea.nl" target="_blank" rel="noopener" class="text-ice/70 hover:text-aqua-light">Agensea</a></p>
    </div>
  </div>

  <span aria-hidden="true" class="ghost-num absolute -bottom-6 right-4 sm:right-12 leading-none select-none">thrIVe</span>
</footer>
