---
import { nav, biz } from "../data/site";
const path = Astro.url.pathname;
---
<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <div class="wrap-wide pt-3 sm:pt-4">
    <div class="pill-nav flex items-center justify-between gap-3 rounded-full pl-5 pr-2.5 py-2.5">
      <a href="/" class="font-display text-2xl font-semibold tracking-tight shrink-0" aria-label={biz.name}>thr<span class="text-gold-deep">IV</span>e</a>

      <nav class="hidden lg:flex items-center gap-1">
        {nav.map((n) => (
          <a href={n.href} class:list={["nav-link rounded-full px-3.5 py-2 text-sm font-semibold transition-colors", path === n.href && "is-active"]} style="font-family:var(--font-display)">{n.label}</a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <a href={biz.bookingUrl} target="_blank" rel="noopener" class="hidden sm:inline-flex btn-primary btn-press !py-2.5 !px-5 text-sm">Book now</a>
        <button id="menu-toggle" class="lg:hidden grid place-items-center w-10 h-10 rounded-full" aria-label="Open menu" aria-expanded="false">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 7h18M3 12h18M3 17h18"/></svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile sheet -->
<div id="mobile-menu" class="section-dark fixed inset-0 z-[60] -translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] lg:hidden flex flex-col bg-mesh-deep">
  <div class="wrap flex items-center justify-between h-[68px] pt-2">
    <span class="font-display text-2xl font-semibold text-paper">thr<span class="text-gold-soft">IV</span>e</span>
    <button id="menu-close" class="grid place-items-center w-11 h-11 rounded-full border border-white/15 text-paper" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
    </button>
  </div>
  <nav class="flex-1 flex flex-col justify-center gap-1 wrap">
    {nav.map((n, i) => (
      <a href={n.href} class="mob-link font-display text-3xl font-semibold py-2.5 text-paper/90" style={`transition-delay:${i * 35}ms`}>{n.label}</a>
    ))}
  </nav>
  <div class="wrap pb-10 flex flex-col gap-3">
    <a href={biz.bookingUrl} target="_blank" rel="noopener" class="btn-primary btn-press w-full justify-center">Book your visit</a>
    <a href={biz.phoneHref} class="btn-ghost btn-press w-full justify-center !text-paper !border-white/25">Call {biz.phone}</a>
  </div>
</div>

<style>
  #site-header { transition: transform 0.4s var(--ease-quint); }
  .nav-link { color: var(--color-ink); }
  .nav-link:hover { background: color-mix(in oklab, var(--color-ink) 7%, transparent); }
  .nav-link.is-active { color: var(--color-gold-deep); background: color-mix(in oklab, var(--color-gold) 14%, transparent); }
  .mob-link { border-bottom: 1px solid rgba(255,255,255,0.1); transition: color 0.3s, padding-left 0.3s var(--ease-quint); }
  .mob-link:hover { color: var(--color-gold-soft); padding-left: 0.5rem; }
  #mobile-menu.open { transform: translateY(0); }
  /* hide on scroll-down, show on scroll-up */
  #site-header.nav-hidden { transform: translateY(-130%); }
</style>

<script>
  const header = document.getElementById("site-header")!;
  let last = 0;
  const onScroll = () => {
    const y = window.scrollY;
    if (y > 200 && y > last) header.classList.add("nav-hidden");
    else header.classList.remove("nav-hidden");
    last = y;
  };
  window.addEventListener("scroll", () => requestAnimationFrame(onScroll), { passive: true });

  const menu = document.getElementById("mobile-menu");
  const toggle = document.getElementById("menu-toggle");
  toggle?.addEventListener("click", () => { menu?.classList.add("open"); toggle.setAttribute("aria-expanded", "true"); });
  document.getElementById("menu-close")?.addEventListener("click", () => { menu?.classList.remove("open"); toggle?.setAttribute("aria-expanded", "false"); });
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => menu.classList.remove("open")));
</script>
